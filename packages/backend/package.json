{
  "name": "personal-finance-backend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build && NODE_ENV=dev drizzle-kit migrate",
    "start": "node dist/server.js",
    "start:dev": "NODE_ENV=dev node dist/server.js",
    "local": "NODE_ENV=local vite-node src/server.ts",
    "test:e2e": "NODE_ENV=test npx playwright test e2e",
    "test:unit": "vitest run src --passWithNoTests",
    "test:all": "npm run test:unit && npm run test:e2e",
    "types:lint": "tsc --noEmit && eslint .",
    "e2e:test": "NODE_ENV=test npx playwright test",
    "db:mig": "npx drizzle-kit migrate",
    "db:gen:mig": "npx drizzle-kit generate && npx drizzle-kit migrate",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@hono/node-server": "^1.19.5",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.0",
    "better-auth": "^1.3.27",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.9.9",
    "koa": "^2.15.0",
    "koa-bodyparser": "^4.4.1",
    "pg": "^8.16.3",
    "zod": "^4.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/koa": "^2.13.6",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^8.0.7",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.4",
    "ts-node": "^10.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0",
    "vite-node": "^2.1.9"
  }
}
